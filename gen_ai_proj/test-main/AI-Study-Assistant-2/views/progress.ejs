<%- include('partials/header') %>

<div class="progress-page">
  <div class="container">

    <!-- Page Header -->
    <div style="margin-bottom:40px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <h1 style="font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:6px;">
          📊 My <span class="text-gradient">Progress</span>
        </h1>
        <p style="color:var(--text-muted);margin:0;">Track your learning journey, <%= user.name.split(' ')[0] %></p>
      </div>
      <div style="display:flex;gap:12px;">
        <a href="/quiz" class="btn-primary-custom" style="padding:10px 22px;font-size:0.9rem;">
          <i class="bi bi-play-fill"></i> New Quiz
        </a>
        <a href="/dashboard" class="btn-secondary-custom" style="padding:10px 22px;font-size:0.9rem;">
          <i class="bi bi-house"></i> Dashboard
        </a>
      </div>
    </div>

    <!-- ── STATS SUMMARY ──────────────────────────────────── -->
    <div class="row g-3 mb-5">
      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-icon">📝</div>
          <div class="stat-value text-gradient"><%= totalQuizzes %></div>
          <div class="stat-label">Total Quizzes</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-icon">🏆</div>
          <div class="stat-value" style="color:var(--warning)"><%= bestScore %>%</div>
          <div class="stat-label">Best Score</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-icon">📊</div>
          <div class="stat-value" style="color:var(--success)"><%= avgScore %>%</div>
          <div class="stat-label">Average Score</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-icon">🎯</div>
          <div class="stat-value" style="color:var(--secondary)">
            <%= bestScore >= 80 ? 'Expert' : bestScore >= 60 ? 'Good' : bestScore >= 40 ? 'Learning' : 'Beginner' %>
          </div>
          <div class="stat-label">Current Level</div>
        </div>
      </div>
    </div>

    <div class="row g-4">

      <!-- ── PERFORMANCE BARS ────────────────────────────── -->
      <div class="col-lg-5">
        <div style="background:var(--bg-glass);border:1px solid var(--border);border-radius:var(--radius-xl);padding:32px;">
          <h5 style="margin-bottom:24px;font-size:1rem;font-weight:700;">Performance Overview</h5>

          <!-- Best Score Bar -->
          <div style="margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
              <span style="font-size:0.85rem;color:var(--text-secondary);">Best Score</span>
              <span style="font-size:0.85rem;font-weight:700;color:var(--warning);"><%= bestScore %>%</span>
            </div>
            <div class="progress-bar-custom">
              <div class="progress-fill" style="width:<%= bestScore %>%;background:linear-gradient(90deg,#fdcb6e,#e17055);"></div>
            </div>
          </div>

          <!-- Average Score Bar -->
          <div style="margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
              <span style="font-size:0.85rem;color:var(--text-secondary);">Average Score</span>
              <span style="font-size:0.85rem;font-weight:700;color:var(--success);"><%= avgScore %>%</span>
            </div>
            <div class="progress-bar-custom">
              <div class="progress-fill" style="width:<%= avgScore %>%;background:linear-gradient(90deg,#00b894,#00cec9);"></div>
            </div>
          </div>

          <!-- Pass Rate (>= 60%) -->
          <% const passRate = totalQuizzes > 0 ? Math.round((scores.filter(s => s.percentage >= 60).length / totalQuizzes) * 100) : 0; %>
          <div style="margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
              <span style="font-size:0.85rem;color:var(--text-secondary);">Pass Rate (≥60%)</span>
              <span style="font-size:0.85rem;font-weight:700;color:var(--primary-light);"><%= passRate %>%</span>
            </div>
            <div class="progress-bar-custom">
              <div class="progress-fill" style="width:<%= passRate %>%;"></div>
            </div>
          </div>

          <!-- Level Progress -->
          <div style="margin-top:32px;padding:20px;background:rgba(108,99,255,0.08);border:1px solid rgba(108,99,255,0.15);border-radius:var(--radius-md);">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
              <span style="font-size:1.8rem;">
                <%= bestScore >= 80 ? '🏆' : bestScore >= 60 ? '⭐' : bestScore >= 40 ? '💪' : '🌱' %>
              </span>
              <div>
                <div style="font-weight:700;">
                  <%= bestScore >= 80 ? 'Expert Level' : bestScore >= 60 ? 'Good Level' : bestScore >= 40 ? 'Learning Level' : 'Beginner Level' %>
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);">
                  <%= bestScore >= 80 ? 'Exceptional performance!' : bestScore >= 60 ? 'Above average' : bestScore >= 40 ? 'Keep practicing' : 'Just getting started' %>
                </div>
              </div>
            </div>
            <% const nextMilestone = bestScore >= 80 ? 100 : bestScore >= 60 ? 80 : bestScore >= 40 ? 60 : 40; %>
            <p style="font-size:0.8rem;color:var(--text-muted);margin:0;">
              <%= nextMilestone - bestScore > 0 ? `${nextMilestone - bestScore}% more to reach next level!` : 'You\'ve reached the top! 🎉' %>
            </p>
          </div>
        </div>
      </div>

      <!-- ── QUIZ HISTORY ─────────────────────────────────── -->
      <div class="col-lg-7">
        <div style="background:var(--bg-glass);border:1px solid var(--border);border-radius:var(--radius-xl);padding:32px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
            <h5 style="margin:0;font-size:1rem;font-weight:700;">Quiz History</h5>
            <span style="font-size:0.8rem;color:var(--text-muted);"><%= totalQuizzes %> total</span>
          </div>

          <% if (scores.length === 0) { %>
          <!-- Empty state -->
          <div style="text-align:center;padding:48px 20px;">
            <div style="font-size:3rem;margin-bottom:16px;">🎯</div>
            <h5 style="margin-bottom:8px;">No quizzes yet!</h5>
            <p style="color:var(--text-secondary);margin-bottom:24px;">Take your first quiz to see your progress here</p>
            <a href="/quiz" class="btn-primary-custom" style="padding:12px 24px;">
              <i class="bi bi-play-fill"></i> Start First Quiz
            </a>
          </div>
          <% } else { %>

          <div style="max-height:480px;overflow-y:auto;padding-right:4px;">
            <% scores.forEach(function(s, i) { %>
            <div class="score-history-card">
              <!-- Score badge -->
              <div class="score-badge <%= s.percentage >= 70 ? 'excellent' : s.percentage >= 50 ? 'good' : 'needs-work' %>">
                <%= s.percentage %>%
              </div>

              <!-- Info -->
              <div style="flex:1;">
                <div style="font-weight:600;margin-bottom:4px;">
                  <%= s.score %>/<%= s.total %> correct
                  <% if (i === 0) { %><span style="font-size:0.7rem;color:var(--primary-light);margin-left:8px;background:rgba(108,99,255,0.1);padding:2px 8px;border-radius:50px;">Latest</span><% } %>
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);">
                  <i class="bi bi-calendar3 me-1"></i>
                  <%= new Date(s.dateTaken).toLocaleDateString('en-US', {weekday:'short',month:'short',day:'numeric',year:'numeric'}) %>
                </div>
              </div>

              <!-- Score emoji -->
              <div style="font-size:1.3rem;">
                <%= s.percentage >= 80 ? '🏆' : s.percentage >= 60 ? '⭐' : s.percentage >= 40 ? '💪' : '📚' %>
              </div>
            </div>
            <% }) %>
          </div>

          <% } %>
        </div>
      </div>

    </div>

    <!-- ── TIPS SECTION ────────────────────────────────────── -->
    <div style="margin-top:32px;background:linear-gradient(135deg,rgba(0,206,201,0.08),rgba(108,99,255,0.08));border:1px solid rgba(0,206,201,0.15);border-radius:var(--radius-xl);padding:32px;">
      <h5 style="margin-bottom:16px;">💡 Tips to Improve Your Score</h5>
      <div class="row g-3">
        <div class="col-md-4">
          <div style="padding:16px;background:rgba(255,255,255,0.03);border-radius:var(--radius-md);">
            <div style="font-size:1.5rem;margin-bottom:8px;">🤖</div>
            <strong>Use the Chatbot</strong>
            <p style="color:var(--text-secondary);font-size:0.85rem;margin:4px 0 0;">Ask AI to explain topics you got wrong</p>
          </div>
        </div>
        <div class="col-md-4">
          <div style="padding:16px;background:rgba(255,255,255,0.03);border-radius:var(--radius-md);">
            <div style="font-size:1.5rem;margin-bottom:8px;">🔄</div>
            <strong>Practice Daily</strong>
            <p style="color:var(--text-secondary);font-size:0.85rem;margin:4px 0 0;">Take at least one quiz per day for best results</p>
          </div>
        </div>
        <div class="col-md-4">
          <div style="padding:16px;background:rgba(255,255,255,0.03);border-radius:var(--radius-md);">
            <div style="font-size:1.5rem;margin-bottom:8px;">📖</div>
            <strong>Review Explanations</strong>
            <p style="color:var(--text-secondary);font-size:0.85rem;margin:4px 0 0;">Read the explanation for every wrong answer</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
