<%- include('partials/header') %>

<div class="result-page">
  <div class="container" style="max-width:760px;">

    <!-- Result Hero Card -->
    <div class="result-hero-card">

      <!-- Emoji based on score -->
      <div style="font-size:3rem;margin-bottom:20px;">
        <% if (percentage >= 80) { %>🏆
        <% } else if (percentage >= 60) { %>⭐
        <% } else if (percentage >= 40) { %>💪
        <% } else { %>📚<% } %>
      </div>

      <!-- Score Circle (CSS conic-gradient) -->
      <div class="score-circle" style="--pct: <%= percentage %>%;">
        <div class="score-inner">
          <div class="score-number text-gradient"><%= percentage %>%</div>
          <div class="score-label">Score</div>
        </div>
      </div>

      <!-- Result Title -->
      <h2 style="font-size:2rem;margin-bottom:8px;">
        <% if (percentage >= 80) { %>Outstanding! 🎉
        <% } else if (percentage >= 60) { %>Great Job! 👏
        <% } else if (percentage >= 40) { %>Keep Going! 💪
        <% } else { %>Study More! 📚<% } %>
      </h2>

      <p style="color:var(--text-secondary);font-size:1rem;margin-bottom:32px;">
        You got <strong style="color:var(--text-primary);"><%= score %> out of <%= total %></strong> questions correct
      </p>

      <!-- Score breakdown boxes -->
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <div style="text-align:center;padding:16px 24px;background:rgba(0,184,148,0.1);border:1px solid rgba(0,184,148,0.2);border-radius:var(--radius-md);">
          <div style="font-size:1.6rem;font-weight:700;color:#00b894;"><%= score %></div>
          <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Correct</div>
        </div>
        <div style="text-align:center;padding:16px 24px;background:rgba(214,48,49,0.1);border:1px solid rgba(214,48,49,0.2);border-radius:var(--radius-md);">
          <div style="font-size:1.6rem;font-weight:700;color:#ff7675;"><%= total - score %></div>
          <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Wrong</div>
        </div>
        <div style="text-align:center;padding:16px 24px;background:rgba(108,99,255,0.1);border:1px solid rgba(108,99,255,0.2);border-radius:var(--radius-md);">
          <div style="font-size:1.6rem;font-weight:700;color:var(--primary-light);"><%= total %></div>
          <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Total</div>
        </div>
      </div>

    </div>

    <!-- Action Buttons -->
    <div style="display:flex;gap:12px;justify-content:center;margin-bottom:48px;flex-wrap:wrap;">
      <a href="/quiz" class="btn-primary-custom">
        <i class="bi bi-arrow-repeat"></i> Try Again
      </a>
      <a href="/progress" class="btn-secondary-custom">
        <i class="bi bi-bar-chart"></i> View Progress
      </a>
      <a href="/dashboard" class="btn-secondary-custom">
        <i class="bi bi-house"></i> Dashboard
      </a>
    </div>

    <!-- Question Review Section -->
    <h4 style="margin-bottom:20px;font-size:1.1rem;">
      <i class="bi bi-clipboard-check me-2" style="color:var(--primary-light);"></i>
      Detailed Review
    </h4>

    <% results.forEach(function(r, i) { %>
    <div class="result-question-card <%= r.isCorrect ? 'correct' : 'wrong' %>">

      <!-- Correct/Wrong Badge -->
      <div class="result-badge <%= r.isCorrect ? 'badge-correct' : 'badge-wrong' %>">
        <i class="bi <%= r.isCorrect ? 'bi-check-circle-fill' : 'bi-x-circle-fill' %>"></i>
        <%= r.isCorrect ? 'Correct' : 'Incorrect' %>
      </div>

      <!-- Question Text -->
      <p style="font-weight:600;margin-bottom:16px;font-size:1rem;">
        <span style="color:var(--text-muted);">Q<%= i+1 %>.</span> <%= r.questionText %>
      </p>

      <!-- Show selected and correct answers -->
      <% const letters = ['A', 'B', 'C', 'D']; %>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
        <% r.options.forEach(function(opt, idx) { %>
        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--radius-sm);
          background:<%= idx === r.correctAnswerIndex ? 'rgba(0,184,148,0.1)' : (idx === r.selectedIndex && !r.isCorrect) ? 'rgba(214,48,49,0.1)' : 'rgba(255,255,255,0.03)' %>;
          border:1px solid <%= idx === r.correctAnswerIndex ? 'rgba(0,184,148,0.3)' : (idx === r.selectedIndex && !r.isCorrect) ? 'rgba(214,48,49,0.3)' : 'var(--border)' %>;">

          <span style="width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;
            background:<%= idx === r.correctAnswerIndex ? 'rgba(0,184,148,0.3)' : (idx === r.selectedIndex && !r.isCorrect) ? 'rgba(214,48,49,0.3)' : 'var(--border)' %>;
            color:<%= idx === r.correctAnswerIndex ? '#00b894' : (idx === r.selectedIndex && !r.isCorrect) ? '#ff7675' : 'var(--text-muted)' %>;">
            <%= letters[idx] %>
          </span>

          <span style="flex:1;font-size:0.9rem;color:<%= idx === r.correctAnswerIndex ? '#00b894' : (idx === r.selectedIndex && !r.isCorrect) ? '#ff7675' : 'var(--text-secondary)' %>;">
            <%= opt %>
          </span>

          <% if (idx === r.correctAnswerIndex) { %>
          <i class="bi bi-check-circle-fill" style="color:#00b894;"></i>
          <% } else if (idx === r.selectedIndex && !r.isCorrect) { %>
          <i class="bi bi-x-circle-fill" style="color:#ff7675;"></i>
          <% } %>
        </div>
        <% }) %>
      </div>

      <!-- Explanation -->
      <% if (r.explanation) { %>
      <div style="padding:12px 16px;background:rgba(108,99,255,0.08);border:1px solid rgba(108,99,255,0.15);border-radius:var(--radius-sm);">
        <p style="margin:0;font-size:0.85rem;color:var(--primary-light);">
          <i class="bi bi-lightbulb-fill me-2"></i><strong>Explanation:</strong> <%= r.explanation %>
        </p>
      </div>
      <% } %>

    </div>
    <% }) %>

    <!-- Bottom buttons -->
    <div style="display:flex;gap:12px;justify-content:center;margin-top:32px;flex-wrap:wrap;">
      <a href="/quiz" class="btn-primary-custom">
        <i class="bi bi-arrow-repeat"></i> Take Another Quiz
      </a>
      <a href="/dashboard" class="btn-secondary-custom">
        <i class="bi bi-house"></i> Go to Dashboard
      </a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
