<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — AI Study Assistant</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-noise">

  <!-- Animated Background Orbs -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <!-- ── NAVBAR ─────────────────────────────────────────────── -->
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/">
        🎓 AI<span>Study</span>
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain"
        style="border-color: var(--border); color: var(--text-primary);">
        <i class="bi bi-list" style="font-size:1.5rem;"></i>
      </button>

      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav ms-auto align-items-center gap-1">
          <% if (currentUser) { %>
            <!-- Logged in links -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard">
                <i class="bi bi-grid-1x2 me-1"></i>Dashboard
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/chatbot">
                <i class="bi bi-chat-dots me-1"></i>AI Chat
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/quiz">
                <i class="bi bi-patch-question me-1"></i>Quiz
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/progress">
                <i class="bi bi-bar-chart me-1"></i>Progress
              </a>
            </li>
            <li class="nav-item ms-2">
              <a class="nav-link btn-nav-login" href="/logout">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
              </a>
            </li>
          <% } else { %>
            <!-- Guest links -->
            <li class="nav-item">
              <a class="nav-link" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link btn-nav-login" href="/login">Login</a>
            </li>
            <li class="nav-item">
              <a class="nav-link btn-nav-signup" href="/register">Get Started</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- ── FLASH MESSAGES ────────────────────────────────────── -->
  <div class="flash-container">
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="flash-alert flash-success">
        <i class="bi bi-check-circle-fill me-2"></i><%= success_msg %>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="flash-alert flash-error">
        <i class="bi bi-exclamation-circle-fill me-2"></i><%= error_msg %>
      </div>
    <% } %>
  </div>
